# LLM providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
# API key for DeepSeek service (set to enable DeepSeek features)
DEEPSEEK_API_KEY=
# DeepSeek API base URL (default: https://api.deepseek.com)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Default chat model (namespaced provider/model)
AI_MODEL=openrouter/openai/gpt-5.4-mini

# CV generation model (independent of chat AI_MODEL)
# Must be namespaced as provider/model (e.g. anthropic/sonnet)
TAILOR_MODEL=anthropic/sonnet
# Eval winner 2026-06-03: highest four-dimension composite score (format + relevance + anti-hallucination + extraction)

# Default judge model for unknown generator models in eval pipeline (namespaced provider/model)
EVAL_JUDGE_MODEL=anthropic/sonnet
# Optional JSON object overriding cross-provider judge map (generator → judge); invalid/missing keys fall back to defaults
# EVAL_JUDGE_MAP_JSON={"deepseek/deepseek-v4-pro":"anthropic/sonnet","anthropic/sonnet":"deepseek/deepseek-v4-pro"}
# Comma-separated model strings for eval pipeline; defaults to all four candidate models
EVAL_MODELS=deepseek/deepseek-v4-pro,anthropic/sonnet,openrouter/openai/gpt-5.4-mini,openrouter/google/gemini-2.5-pro
# Model for JD metadata extraction in eval pipeline stage 1 (namespaced provider/model)
EVAL_EXTRACTION_MODEL=openrouter/openai/gpt-4o-mini
# Minimum extraction judge score (0.0–1.0) to proceed to stage 2 CV generation (default 0.7)
EVAL_EXTRACTION_MIN_SCORE=0.7

# LLM-as-Judge system prompts (optional overrides; defaults built into eval-schema.ts)
# RELEVANCE_JUDGE_PROMPT=...
# HALLUCINATION_JUDGE_PROMPT=...
# EXTRACTION_JUDGE_PROMPT=...

AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192
# Use OpenRouter flex pricing tier by default (true/false)
OPENROUTER_FLEX_ENABLED=true
# Hard ceiling for max_tokens across all providers (default 128000)
AI_MAX_TOKENS_LIMIT=128000
# TTL in ms for the Anthropic Models API cache (default 604800000 = 7 days)
ANTHROPIC_MODEL_CACHE_TTL_MS=604800000

# Rate limiting (burst detection per IP)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60000

# LangFuse (optional)
LANGFUSE_TRACING=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT_NAME=

# Railway sets PORT automatically
PORT=3000
