# LLM providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
# API key for DeepSeek service (set to enable DeepSeek features)
DEEPSEEK_API_KEY=
# DeepSeek API base URL (default: https://api.deepseek.com)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Default chat model (namespaced provider/model)
AI_MODEL=openrouter/openai/gpt-5.4-mini

# CV generation model (independent of chat AI_MODEL)
# Must be namespaced as provider/model (e.g. anthropic/sonnet)
TAILOR_MODEL=anthropic/sonnet
# Eval winner 2026-06-03: highest four-dimension composite score (format + relevance + anti-hallucination + extraction)

# Default judge model for unknown generator models in eval pipeline (namespaced provider/model)
EVAL_JUDGE_MODEL=openrouter/google/gemini-3.1-pro-preview
# Optional JSON object overriding cross-provider judge map (generator → judge); invalid/missing keys fall back to defaults
# EVAL_JUDGE_MAP_JSON={"deepseek/deepseek-v4-pro":"openrouter/google/gemini-3.1-pro-preview","openrouter/qwen/qwen3.7-max":"openrouter/google/gemini-3.1-pro-preview","openrouter/xiaomi/mimo-v2.5-pro":"openrouter/google/gemini-3.1-pro-preview","openrouter/minimax/minimax-m3":"openrouter/google/gemini-3.1-pro-preview","anthropic/sonnet":"openrouter/openai/gpt-5.4","anthropic/opus":"openrouter/openai/gpt-5.4","openrouter/google/gemini-3.1-pro-preview":"openrouter/openai/gpt-5.4","openrouter/openai/gpt-5.4":"openrouter/google/gemini-3.1-pro-preview","openrouter/openai/gpt-5.5":"openrouter/google/gemini-3.1-pro-preview"}
# Comma-separated model strings for eval pipeline; defaults to all candidate models
EVAL_MODELS=deepseek/deepseek-v4-pro,openrouter/qwen/qwen3.7-max,openrouter/xiaomi/mimo-v2.5-pro,openrouter/minimax/minimax-m3,openrouter/google/gemini-3.1-pro-preview,openrouter/openai/gpt-5.4,openrouter/openai/gpt-5.5,anthropic/sonnet,anthropic/opus
# Model for JD metadata extraction in eval pipeline stage 1 (namespaced provider/model)
EVAL_EXTRACTION_MODEL=openrouter/openai/gpt-5.4-mini
# Minimum extraction judge score (0.0–1.0) to proceed to stage 2 CV generation (default 0.7)
EVAL_EXTRACTION_MIN_SCORE=0.7

# LLM-as-Judge system prompts (optional overrides; defaults built into eval-schema.ts)
# RELEVANCE_JUDGE_PROMPT=...
# HALLUCINATION_JUDGE_PROMPT=...
# EXTRACTION_JUDGE_PROMPT=...

AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192
# Use OpenRouter flex pricing tier by default (true/false)
OPENROUTER_FLEX_ENABLED=true
# Hard ceiling for max_tokens across all providers (default 128000)
AI_MAX_TOKENS_LIMIT=128000
# TTL in ms for the Anthropic Models API cache (default 604800000 = 7 days)
ANTHROPIC_MODEL_CACHE_TTL_MS=604800000

# Rate limiting (burst detection per IP + per shared-secret hash)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60000
# Per-shared-secret ceiling (default: floor(RATE_LIMIT_MAX / 2), min 1)
# RATE_LIMIT_SECRET_MAX=2
# Max ms to wait for Upstash rate-limit check before fail-closed 503 (default 2000)
RATE_LIMIT_TIMEOUT_MS=2000
# Redis key prefix for rate-limit state (default: ratelimit)
RATE_LIMIT_REDIS_PREFIX=ratelimit
# Upstash Redis REST API (required for distributed rate limiting; from Upstash console → REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# LangFuse (optional)
LANGFUSE_TRACING=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Max ms to wait for Langfuse span export before continuing (default 5000)
LANGFUSE_FLUSH_TIMEOUT_MS=5000

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT_NAME=

# Railway sets PORT automatically
PORT=3000

# Canonical master CV JSON (career PII — never commit real content)
# Prefer embedding JSON in env for Railway/local secrets (MASTER_CV_JSON).
# Alternative: path to a gitignored file.
# MASTER_CV_JSON={"name":"..."}
MASTER_CV_PATH=secrets/master_cv.json

# Shared secret for POST /api/tailor-cv — only smoke CLI and CCC backend present this.
# Clients must send: Authorization: Bearer <TAILOR_API_KEY>
TAILOR_API_KEY=

# Local/dev only: skip Bearer auth when set to 1/true. Default off.
# Hard-blocked when NODE_ENV=production or RAILWAY_ENVIRONMENT/VERCEL_ENV=production.
# TAILOR_AUTH_INSECURE_BYPASS=1

# Size limits (JSON curator pipeline)
# TAILOR_REQUEST_MAX_BYTES=65536
# TAILOR_JD_MAX_CHARS=50000
# TAILOR_CURATED_JSON_MAX_BYTES=512000
# TAILOR_RESPONSE_MAX_BYTES=2097152

