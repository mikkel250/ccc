# LLM providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# CV generation model (independent of chat AI_MODEL)
TAILOR_MODEL=gemini-2.5-pro
AI_MODEL_FALLBACKS=gemini-2.5-flash,gpt-4o-mini

AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192

# Rate limiting (burst detection per IP)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60000

# LangFuse (optional)
LANGFUSE_TRACING=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT_NAME=

# Railway sets PORT automatically
PORT=3000
