# LLM providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# CV generation model (independent of chat AI_MODEL)
# Use provider/model for OpenRouter (e.g. google/gemini-2.5-pro) or native names (e.g. gemini-2.5-pro)
TAILOR_MODEL=gemini-2.5-pro

AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192

# Rate limiting (burst detection per IP)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60000

# LangFuse (optional)
LANGFUSE_TRACING=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT_NAME=

# Railway sets PORT automatically
PORT=3000
