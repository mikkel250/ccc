{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/ccc/master-cv.schema.json",
  "title": "MasterOrCuratedCV",
  "description": "Schema compatible with Claude Projects master_cv.json / curated subset. Experience entries use either bullets[] or subroles[].",
  "type": "object",
  "required": [
    "name",
    "contact",
    "summary",
    "skills",
    "experience",
    "education"
  ],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string"
    },
    "contact": {
      "type": "object",
      "required": [
        "location",
        "phone",
        "email",
        "links"
      ],
      "properties": {
        "location": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "label",
              "url"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "category",
          "items"
        ],
        "properties": {
          "category": {
            "type": "string"
          },
          "items": {
            "type": "string"
          }
        }
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "dates"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "dates": {
            "type": "string"
          },
          "blurb": {
            "type": "string"
          },
          "bullets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "subroles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "heading",
                "bullets"
              ],
              "properties": {
                "heading": {
                  "type": "string"
                },
                "bullets": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "bullets"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "linkLabel": {
            "type": "string"
          },
          "linkUrl": {
            "type": "string"
          },
          "bullets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "portfolioSites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "certifications": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
